{
  "manifest_version": 3,
  "name": "Bookmark Base",
  "version": "1.1.0",
  "description": "Save and organize bookmarks from X (Twitter) and Reddit. Sync your saved posts to bookmarkbase.online for easy access.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://cdn.syndication.twimg.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://*.x.com/*"
      ],
      "js": [
        "twitter-content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://reddit.com/*",
        "https://*.reddit.com/*"
      ],
      "js": [
        "reddit-content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://bookmarkbase.online/*"
      ],
      "js": [
        "webapp-sync.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Bookmark Base",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}